    <changeSet id="1" author="lesha226@yandex.ru">
        <!--
            create table if not exists items (
                id          bigint          generated by default as identity,
                title       varchar         not null,
                description varchar(2000)   not null,
                img_path    varchar         not null,
                price       bigint          not null,
                constraint pk_items primary key (id),
                constraint uk_items unique (title)
            );
        -->
        <createTable tableName="items">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_items" nullable="false"/>
            </column>
            <column name="title" type="varchar">
                <constraints unique="true" uniqueConstraintName="uk_items" nullable="false"/>
            </column>
            <column name="description" type="varchar(2000)">
                <constraints nullable="false"/>
            </column>
            <column name="img_path" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="lesha226@yandex.ru">
        <!--
            create table if not exists cart_items(
                item_id     bigint          not null,
                count       integer         not null,
                constraint pk_cart_items primary key (item_id)
            );
        -->
        <createTable tableName="cart_items">
            <column name="id" type="bigint">
                <constraints primaryKey="true" primaryKeyName="pk_cart_items" nullable="false"/>
            </column>
            <column name="count" type="integer">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="3" author="lesha226@yandex.ru">
        <!--
            create table if not exists orders (
                id  bigint  generated by default as identity,
                constraint pk_orders primary key (id)
            );
        -->
        <createTable tableName="orders">
            <column name="id" type="bigint">
                <constraints primaryKey="true" primaryKeyName="pk_orders" nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="4" author="lesha226@yandex.ru">
        <!--
            create table if not exists order_items (
                id          bigint          generated by default as identity,
                order_id    bigint          not null,
                item_id     bigint          not null,
                count       integer         not null,
                constraint pk_order_items primary key (id),
                constraint uk_order_items unique (order_id, item_id),
                constraint fk_order_items_item_id foreign key (item_id) references items(id),
                constraint fk_order_items_order_id foreign key (order_id) references orders(id)
            );
        -->
        <createTable tableName="order_items">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_order_items" nullable="false"/>
            </column>
            <column name="order_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="item_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="count" type="integer">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="order_items"
                             columnNames="order_id, item_id"
                             constraintName="uk_order_items"/>

        <addForeignKeyConstraint baseTableName="order_items"
                                 baseColumnNames="item_id"
                                 constraintName="fk_order_items_item_id"
                                 referencedTableName="items"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="order_items"
                                 baseColumnNames="order_id"
                                 constraintName="fk_order_items_order_id"
                                 referencedTableName="orders"
                                 referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="5" author="lesha226@yandex.ru">
        <sql>
            insert into items(title, description, img_path, price)
            with src as (
                values
                    ('Title 1', 'Some description 1', 'images/1.jpeg', 1),
                    ('Title 2', 'Some description 2', 'images/2.jpeg', 2),
                    ('Title 3', 'Some description 3', 'images/3.jpeg', 3),
                    ('Title 4', 'Some description 4', 'images/4.jpeg', 4),
                    ('Title 5', 'Some description 5', 'images/5.jpeg', 5)
            )
            select *
            from src
            where not exists(select 1 from items);
        </sql>
    </changeSet>
</databaseChangeLog>