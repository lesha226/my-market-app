<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="create-items" author="lesha226@yandex.ru">
        <preConditions>
            <not>
                <tableExists tableName="items"/>
            </not>
        </preConditions>
        <!--
            create table if not exists items (
                id          bigint          generated by default as identity,
                title       varchar         not null,
                description varchar(2000)   not null,
                img_path    varchar         not null,
                price       bigint          not null,
                constraint pk_items primary key (id),
                constraint uk_items unique (title)
            );
        -->
        <createTable tableName="items">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_items" nullable="false"/>
            </column>
            <column name="title" type="varchar">
                <constraints unique="true" uniqueConstraintName="uk_items" nullable="false"/>
            </column>
            <column name="description" type="varchar(2000)">
                <constraints nullable="false"/>
            </column>
            <column name="img_path" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="items"/>
        </rollback>
    </changeSet>
</databaseChangeLog>